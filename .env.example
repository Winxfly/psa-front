# Optional. Used only by the local Vite dev proxy.
# Keep the frontend API base URL same-origin (/api/v1) for both local and production.
#
# Direct backend on host:
# API_PROXY_TARGET=http://host.docker.internal:8080
#
# Backend behind local Caddy on host:
# API_PROXY_TARGET=https://host.docker.internal
API_PROXY_TARGET=http://host.docker.internal:8080
